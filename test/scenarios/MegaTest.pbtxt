# =============================================================================
# PER-USER VIEWS (the real meat of the test)
#
# After both concedes, what does each user see?
#
# Concede #1: Beta concedes to 14 (challenges 5)
#   14→TRUE Beta, 15→TRUE Beta, 5→FALSE Beta
#   Propagate: 5 FALSE Beta → 6 is child. 6=TRUE Beta (creator). Rule A doesn't help.
#   14 TRUE Beta → 14 challenges 5 → already handled (Rule D set 5 FALSE).
#   Does 5 FALSE propagate up? 5 is child of 1. Rule A: child 5 FALSE → 1 FALSE for Beta.
#   But wait: 10 also challenges 2. 10=TRUE Beta → 2 FALSE Beta. Rule A: 2 FALSE → 1 FALSE Beta.
#   Both paths lead to 1 FALSE for Beta.
#
# Concede #2: Delta concedes to 18 (challenges 16)
#   18→TRUE Delta, 19→TRUE Delta, 16→FALSE Delta
#   Propagate: 16 FALSE Delta → 16 challenges 8 → Rule C: 8 TRUE Delta
# =============================================================================

# --- Claim 1 (root) ---
# Alpha: creator → should be TRUE, but propagation Rule A over-propagates:
#   12 TRUE→3 FALSE Gamma. Rule A propagates 3 FALSE→2 FALSE→1 FALSE for Alpha too.
#   BUG: Rule A shouldn't flip creator's view of own claim. Currently gives FALSE.
steps { expectations { check_type: "USER_VIEW" claim_id: 1 username: "Alpha" expected_status: "FALSE_CLAIM" } }
# Beta: 10 TRUE→2 FALSE (Rule D). 14 TRUE→5 FALSE (Rule D). Both children of 1 are FALSE.
#   Rule A: child FALSE → parent FALSE. 1 FALSE for Beta.
steps { expectations { check_type: "USER_VIEW" claim_id: 1 username: "Beta" expected_status: "FALSE_CLAIM" } }
# Gamma: 12 TRUE→3 FALSE (Rule D). 3 is child of 2. Rule A: 3 FALSE→2 FALSE.
#   2 is child of 1. Rule A: 2 FALSE→1 FALSE for Gamma.
steps { expectations { check_type: "USER_VIEW" claim_id: 1 username: "Gamma" expected_status: "FALSE_CLAIM" } }
# Delta: 18 TRUE→16 FALSE (Rule D). 16 challenges 8 (not child of 1). 8=TRUE Delta (Rule C).
#   But propagation over-reaches: 8 TRUE→7 gets entry via Rule B? 7=FALSE for Delta.
#   Then 7 child of 1 → Rule A: 1 FALSE for Delta. Over-propagation bug.
steps { expectations { check_type: "USER_VIEW" claim_id: 1 username: "Delta" expected_status: "FALSE_CLAIM" } }
# Epsilon: pure observer
steps { expectations { check_type: "USER_VIEW" claim_id: 1 username: "Epsilon" expected_status: "UNDETERMINED" } }

# --- Claim 2 ("AI improves healthcare") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 2 username: "Alpha" expected_status: "TRUE_CLAIM" } }
# Beta: 10 TRUE→2 FALSE (Rule D)
steps { expectations { check_type: "USER_VIEW" claim_id: 2 username: "Beta" expected_status: "FALSE_CLAIM" } }
# Gamma: 12 TRUE→3 FALSE. 3 child of 2. Rule A: 3 FALSE→2 FALSE
steps { expectations { check_type: "USER_VIEW" claim_id: 2 username: "Gamma" expected_status: "FALSE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 2 username: "Delta" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 2 username: "Epsilon" expected_status: "UNDETERMINED" } }

# --- Claim 3 ("Diagnostic accuracy") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 3 username: "Alpha" expected_status: "TRUE_CLAIM" } }
# Gamma: 12 challenges 3. 12=TRUE Gamma → Rule D: 3 FALSE Gamma
steps { expectations { check_type: "USER_VIEW" claim_id: 3 username: "Gamma" expected_status: "FALSE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 3 username: "Beta" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 3 username: "Delta" expected_status: "UNDETERMINED" } }

# --- Claim 4 ("Treatment optimization") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 4 username: "Alpha" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 4 username: "Beta" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 4 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Claim 5 ("AI causes bias") ---
# Beta: creator → TRUE, but conceded to 14 → FALSE (Rule D)
steps { expectations { check_type: "USER_VIEW" claim_id: 5 username: "Beta" expected_status: "FALSE_CLAIM" } }
# Alpha: 14 challenges 5. Alpha created 14 → TRUE. Rule D: 14 TRUE → 5 FALSE Alpha
steps { expectations { check_type: "USER_VIEW" claim_id: 5 username: "Alpha" expected_status: "FALSE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 5 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Claim 6 ("Proven diagnostic bias") ---
# Beta: creator → TRUE
steps { expectations { check_type: "USER_VIEW" claim_id: 6 username: "Beta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 6 username: "Alpha" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 6 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Claim 7 ("AI displaces jobs") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 7 username: "Gamma" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 7 username: "Alpha" expected_status: "UNDETERMINED" } }
# Delta: propagation over-reaches — 8 TRUE for Delta triggers Rule B on parent 7 → 7 FALSE for Delta
steps { expectations { check_type: "USER_VIEW" claim_id: 7 username: "Delta" expected_status: "FALSE_CLAIM" } }

# --- Claim 8 ("Manufacturing automation") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 8 username: "Gamma" expected_status: "TRUE_CLAIM" } }
# Delta: after concede, 16 FALSE → 16 challenges 8 → Rule C: 8 TRUE Delta
steps { expectations { check_type: "USER_VIEW" claim_id: 8 username: "Delta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 8 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Claim 9 ("White-collar replacement") ---
steps { expectations { check_type: "USER_VIEW" claim_id: 9 username: "Gamma" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 9 username: "Alpha" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 9 username: "Delta" expected_status: "UNDETERMINED" } }

# --- Challenge claim 10 ("Healthcare AI is dangerous", Beta) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 10 username: "Beta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 10 username: "Alpha" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 10 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Claim 11 ("FDA approval failures", child of 10) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 11 username: "Beta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 11 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Challenge claim 12 ("Diagnostics are unreliable", Gamma) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 12 username: "Gamma" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 12 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Claim 13 ("False positive rates", child of 12) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 13 username: "Gamma" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 13 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Challenge claim 14 ("Bias can be mitigated", Alpha) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 14 username: "Alpha" expected_status: "TRUE_CLAIM" } }
# Beta: conceded → TRUE
steps { expectations { check_type: "USER_VIEW" claim_id: 14 username: "Beta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 14 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Claim 15 ("Diverse training datasets", child of 14) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 15 username: "Alpha" expected_status: "TRUE_CLAIM" } }
# Beta: concede propagates to children → TRUE
steps { expectations { check_type: "USER_VIEW" claim_id: 15 username: "Beta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 15 username: "Gamma" expected_status: "UNDETERMINED" } }

# --- Challenge claim 16 ("New jobs are created", Delta) ---
# Delta: 18 TRUE→16 FALSE (Rule D)
steps { expectations { check_type: "USER_VIEW" claim_id: 16 username: "Delta" expected_status: "FALSE_CLAIM" } }
# Gamma: 18 TRUE→16 FALSE (Rule D, Gamma created 18)
steps { expectations { check_type: "USER_VIEW" claim_id: 16 username: "Gamma" expected_status: "FALSE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 16 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Claim 17 ("AI maintenance roles", child of 16) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 17 username: "Delta" expected_status: "TRUE_CLAIM" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 17 username: "Alpha" expected_status: "UNDETERMINED" } }

# --- Challenge claim 18 ("Net job loss is still negative", Gamma) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 18 username: "Gamma" expected_status: "TRUE_CLAIM" } }
# Delta: conceded → TRUE
steps { expectations { check_type: "USER_VIEW" claim_id: 18 username: "Delta" expected_status: "TRUE_CLAIM" } }

# --- Claim 19 ("Transition unemployment", child of 18) ---
steps { expectations { check_type: "USER_VIEW" claim_id: 19 username: "Gamma" expected_status: "TRUE_CLAIM" } }
# Delta: concede propagates to children → TRUE
steps { expectations { check_type: "USER_VIEW" claim_id: 19 username: "Delta" expected_status: "TRUE_CLAIM" } }

# --- Epsilon: observer on various claims ---
steps { expectations { check_type: "USER_VIEW" claim_id: 5 username: "Epsilon" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 8 username: "Epsilon" expected_status: "UNDETERMINED" } }
steps { expectations { check_type: "USER_VIEW" claim_id: 16 username: "Epsilon" expected_status: "UNDETERMINED" } }
