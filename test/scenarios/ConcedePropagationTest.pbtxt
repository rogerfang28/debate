name: "ConcedePropagationTest"

# =============================================================================
# Reproduce the debate from the screenshot:
#   1 (root: "tsetset", creator A)
#   └── 2 ("A", creator A, child of 1)
#       ├── 3 ("B", creator A, child of 2)
#       │   └── 5 (challenge→3, "no", creator C)
#       │       └── 6 (challenge→5, "yesy", creator A)
#       └── 4 ("C", creator A, child of 2)
#           ├── 7 ("D", creator A, child of 4)
#           └── 8 ("E", creator A, child of 4)
#
# After A concedes to challenge 6 (which challenges 5):
#   6 → TRUE for A (conceded)
#   5 → FALSE for A (challenged by 6, Rule D)
#   3 → TRUE for A (challenged by 5 which is FALSE, Rule C)
#   2 → still TRUE for A (created, child 3 TRUE, child 4 UNDETERMINED → not all TRUE)
#   1 → still TRUE for A (created, child 2 TRUE)
# =============================================================================

steps {
  action { username: "A" event_type: "CREATE_USER" }
}
steps {
  action { username: "C" event_type: "CREATE_USER" }
}

steps {
  action { username: "A" event_type: "CREATE_DEBATE" debate_topic: "tsetset" }
}

steps {
  action { username: "A" event_type: "JOIN_DEBATE" debate_id: 1 }
}
steps {
  action { username: "A" event_type: "ENTER_DEBATE" debate_id: 1 }
}
steps {
  action { username: "C" event_type: "JOIN_DEBATE" debate_id: 1 }
}
steps {
  action { username: "C" event_type: "ENTER_DEBATE" debate_id: 1 }
}

# A adds child 2 to root 1
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 1 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "A" claim_description: "child of root" }
}

# A adds child 3 to claim 2
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 2 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "B" claim_description: "child of A" }
}

# A adds child 4 to claim 2
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 2 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "C" claim_description: "child of A" }
}

# C challenges claim 3 → creates challenge claim 5
steps {
  action { username: "C" event_type: "GO_TO_CLAIM" claim_id: 3 }
}
steps {
  action { username: "C" event_type: "SUBMIT_CHALLENGE_CLAIM" claim_text: "no" }
}

# A challenges claim 5 → creates challenge claim 6
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 5 }
}
steps {
  action { username: "A" event_type: "SUBMIT_CHALLENGE_CLAIM" claim_text: "yesy" }
}

# A adds child 7 to claim 4
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 4 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "D" claim_description: "child of C" }
}

# A adds child 8 to claim 4
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 4 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "E" claim_description: "child of C" }
}

# =============================================================================
# CONCEDE — A concedes to challenge 6 (which challenges 5)
# =============================================================================
steps {
  action { username: "A" event_type: "CONCEDE_CHALLENGE" }
}

# =============================================================================
# EXPECTATIONS — Verify final state after concede
# =============================================================================

# --- Claim existence ---
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 1 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 1 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 2 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 3 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 4 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 5 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 6 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 7 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 8 }
}

# --- Collection size ---
steps {
  expectations { check_type: "COLLECTION_SIZE" expected_count: 8 }
}

# --- Claim sentences ---
steps {
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 1 expected_claim_sentence: "tsetset" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 2 expected_claim_sentence: "A" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 3 expected_claim_sentence: "B" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 4 expected_claim_sentence: "C" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 5 expected_claim_sentence: "no" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 6 expected_claim_sentence: "yesy" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 7 expected_claim_sentence: "D" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 8 expected_claim_sentence: "E" }
}

# --- Link counts ---
# PARENT_CHILD: 1→2, 2→3, 2→4, 4→7, 4→8 = 5
steps {
  expectations { check_type: "LINK_COUNT" link_type: "PARENT_CHILD" expected_count: 5 }
}
# CHALLENGE: 5→3, 6→5 = 2
steps {
  expectations { check_type: "LINK_COUNT" link_type: "CHALLENGE" expected_count: 2 }
}

# --- Specific links ---
steps {
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 1 to_claim_id: 2 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 2 to_claim_id: 3 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 2 to_claim_id: 4 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 4 to_claim_id: 7 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 4 to_claim_id: 8 }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 5 to_claim_id: 3 }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 6 to_claim_id: 5 }
}

# --- Per-user views after A concedes to challenge 6 ---
# A conceded: 6 TRUE for A (challenge claim conceded to)
# 6 challenges 5: Rule D → 6 TRUE means 5 FALSE for A
# 5 challenges 3: 5 FALSE → Rule C → 3 TRUE for A
# 2 is parent of 3 and 4. 3=TRUE, 4=UNDETERMINED. Not all children TRUE → 2 stays TRUE for A (creator)
# 1 is parent of 2. 2=TRUE → 1 stays TRUE for A (creator)

# Claim 6 (challenge claim A conceded to → TRUE for A)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 6 username: "A" expected_status: "TRUE_CLAIM" }
}
# Claim 5 (challenged by 6, 6 TRUE → Rule D → 5 FALSE for A)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 5 username: "A" expected_status: "FALSE_CLAIM" }
}
# Claim 3 (challenged by 5, 5 FALSE → Rule C → 3 TRUE for A)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 3 username: "A" expected_status: "TRUE_CLAIM" }
}
# Claim 2 (child 3 TRUE, child 4 UNDETERMINED → stays TRUE for A as creator)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 2 username: "A" expected_status: "TRUE_CLAIM" }
}
# Claim 1 (child 2 TRUE → stays TRUE for A as creator)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 1 username: "A" expected_status: "TRUE_CLAIM" }
}
# Claim 4 (A created it → TRUE, no rule overturns it)
steps {
  expectations { check_type: "USER_VIEW" claim_id: 4 username: "A" expected_status: "TRUE_CLAIM" }
}
