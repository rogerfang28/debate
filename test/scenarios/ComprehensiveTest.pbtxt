name: "ComprehensiveTest"

# =============================================================================
# PHASE 1: SETUP ŌĆö Create users and join debate
# =============================================================================

steps {
  action { username: "A" event_type: "CREATE_USER" }
}
steps {
  action { username: "B" event_type: "CREATE_USER" }
}
steps {
  action { username: "C" event_type: "CREATE_USER" }
}

steps {
  action { username: "A" event_type: "CREATE_DEBATE" debate_topic: "Is AI beneficial?" }
}

steps {
  action { username: "A" event_type: "JOIN_DEBATE" debate_id: 1 }
}
steps {
  action { username: "A" event_type: "ENTER_DEBATE" debate_id: 1 }
}
steps {
  action { username: "B" event_type: "JOIN_DEBATE" debate_id: 1 }
}
steps {
  action { username: "B" event_type: "ENTER_DEBATE" debate_id: 1 }
}
steps {
  action { username: "C" event_type: "JOIN_DEBATE" debate_id: 1 }
}
steps {
  action { username: "C" event_type: "ENTER_DEBATE" debate_id: 1 }
}

# =============================================================================
# PHASE 2: ADD BASE CLAIMS
# =============================================================================

# A adds child #2 to root
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 1 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "AI improves healthcare" claim_description: "test" }
}

# A adds child #3 to root
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 1 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "AI causes job displacement" claim_description: "test" }
}

# =============================================================================
# PHASE 3: CHALLENGE CHAIN WITH CHILDREN
# Structure:
#   1 (root)
#   Ōö£ŌöĆŌöĆ 2 (child)
#   Ōö£ŌöĆŌöĆ 3 (child)
#   Ōö£ŌöĆŌöĆ 4 (challengeŌåÆ2, root-level) [B]
#   Ōöé   ŌööŌöĆŌöĆ 5 (child of 4) [B]
#   Ōö£ŌöĆŌöĆ 6 (challengeŌåÆ5, root-level) [A]  ŌåÉ challenges child 5, not root 4
#   Ōöé   ŌööŌöĆŌöĆ 7 (child of 6) [A]
#   Ōö£ŌöĆŌöĆ 8 (challengeŌåÆ7, root-level) [C]  ŌåÉ challenges child 7, not root 6
#   Ōöé   ŌööŌöĆŌöĆ 9 (child of 8) [C]
# =============================================================================

# B goes to claim 2, creates challenge claim #4 targeting claim 2
steps {
  action { username: "B" event_type: "GO_TO_CLAIM" claim_id: 2 }
}
steps {
  action { username: "B" event_type: "SUBMIT_CHALLENGE_CLAIM" claim_text: "Healthcare AI has bias issues" }
}

# B adds child #5 to challenge claim #4
steps {
  action { username: "B" event_type: "GO_TO_CLAIM" claim_id: 4 }
}
steps {
  action { username: "B" event_type: "ADD_CHILD_CLAIM" claim_text: "Bias in diagnostic algorithms" claim_description: "test" }
}

# A goes to child #5, creates challenge claim #6 targeting child #5
# (instead of challenging the challenge root #4)
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 5 }
}
steps {
  action { username: "A" event_type: "SUBMIT_CHALLENGE_CLAIM" claim_text: "Bias can be mitigated with diverse training data" }
}

# A adds child #7 to challenge claim #6
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 6 }
}
steps {
  action { username: "A" event_type: "ADD_CHILD_CLAIM" claim_text: "Diverse datasets exist in medical imaging" claim_description: "test" }
}

# C goes to child #7, creates challenge claim #8 targeting child #7
# (instead of challenging the challenge root #6)
steps {
  action { username: "C" event_type: "GO_TO_CLAIM" claim_id: 7 }
}
steps {
  action { username: "C" event_type: "SUBMIT_CHALLENGE_CLAIM" claim_text: "Diverse data is hard to obtain in practice" }
}

# C adds child #9 to challenge claim #8
steps {
  action { username: "C" event_type: "GO_TO_CLAIM" claim_id: 8 }
}
steps {
  action { username: "C" event_type: "ADD_CHILD_CLAIM" claim_text: "Rare diseases lack data by definition" claim_description: "test" }
}

# =============================================================================
# PHASE 4: CONCEDE ŌĆö A concedes their challenge
# =============================================================================

steps {
  action { username: "A" event_type: "CONCEDE_CHALLENGE" }
}

# =============================================================================
# EXPECTATIONS ŌĆö Verify final state
# =============================================================================

# --- Claim existence ---
steps {
  action { username: "A" event_type: "GO_TO_CLAIM" claim_id: 1 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 1 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 2 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 3 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 4 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 5 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 6 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 7 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 8 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 9 }
}

# --- Total: 9 claims ---
steps {
  expectations { check_type: "COLLECTION_SIZE" expected_count: 9 }
}

# --- Claim sentences ---
steps {
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 1 expected_claim_sentence: "Is AI beneficial?" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 2 expected_claim_sentence: "AI improves healthcare" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 3 expected_claim_sentence: "AI causes job displacement" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 4 expected_claim_sentence: "Healthcare AI has bias issues" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 5 expected_claim_sentence: "Bias in diagnostic algorithms" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 6 expected_claim_sentence: "Bias can be mitigated with diverse training data" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 7 expected_claim_sentence: "Diverse datasets exist in medical imaging" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 8 expected_claim_sentence: "Diverse data is hard to obtain in practice" }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 9 expected_claim_sentence: "Rare diseases lack data by definition" }
}

# --- Link counts ---
# 5 PARENT_CHILD: 1ŌåÆ2, 1ŌåÆ3, 4ŌåÆ5, 6ŌåÆ7, 8ŌåÆ9
steps {
  expectations { check_type: "LINK_COUNT" link_type: "PARENT_CHILD" expected_count: 5 }
}
# 3 CHALLENGE: 4ŌåÆ2, 6ŌåÆ5, 8ŌåÆ7
steps {
  expectations { check_type: "LINK_COUNT" link_type: "CHALLENGE" expected_count: 3 }
}

# --- Specific link existence ---
steps {
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 1 to_claim_id: 2 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 1 to_claim_id: 3 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 4 to_claim_id: 5 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 6 to_claim_id: 7 }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 8 to_claim_id: 9 }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 4 to_claim_id: 2 }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 6 to_claim_id: 5 }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 8 to_claim_id: 7 }
}

# --- Claim 2 "AI improves healthcare" per-user views ---
# A: 8 is TRUE (conceded). 8 challenges 7. Rule D: 8 TRUE ŌåÆ 7 FALSE.
# 7 is child of 6. Rule A: child 7 FALSE ŌåÆ parent 6 FALSE.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE.
# 4 challenges 2. 4 is TRUE. Rule D: incoming challenge 4 TRUE ŌåÆ 2 FALSE.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 2 username: "A" expected_status: "FALSE_CLAIM" }
}
# B: 4 challenges 2. B created 4 (TRUE). Rule D: incoming challenge 4 TRUE ŌåÆ 2 FALSE for B.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 2 username: "B" expected_status: "FALSE_CLAIM" }
}
# C: 8 is TRUE for C. 8 challenges 7. Rule D: 7 FALSE for C.
# 7 is child of 6. Rule A: 6 FALSE for C.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE for C.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE for C.
# 4 challenges 2. 4 is TRUE. Rule D: incoming challenge 4 TRUE ŌåÆ 2 FALSE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 2 username: "C" expected_status: "FALSE_CLAIM" }
}

# --- Claim 3 "AI causes job displacement" per-user views ---
# A created it ŌåÆ TRUE
steps {
  expectations { check_type: "USER_VIEW" claim_id: 3 username: "A" expected_status: "TRUE_CLAIM" }
}
# B, C not involved ŌåÆ UNDETERMINED
steps {
  expectations { check_type: "USER_VIEW" claim_id: 3 username: "B" expected_status: "UNDETERMINED" }
}
steps {
  expectations { check_type: "USER_VIEW" claim_id: 3 username: "C" expected_status: "UNDETERMINED" }
}

# --- Claim 4 "Healthcare AI has bias issues" (challengeŌåÆ2, root-level) per-user views ---
# B created it ŌåÆ TRUE
steps {
  expectations { check_type: "USER_VIEW" claim_id: 4 username: "B" expected_status: "TRUE_CLAIM" }
}
# A: 8 is TRUE (conceded). 8 challenges 7. Rule D: 8 TRUE ŌåÆ 7 FALSE.
# 7 is child of 6. Rule A: child 7 FALSE ŌåÆ parent 6 FALSE.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE for A.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 4 username: "A" expected_status: "TRUE_CLAIM" }
}
# C: 8 is TRUE for C. 8 challenges 7. Rule D: 7 FALSE for C.
# 7 is child of 6. Rule A: 6 FALSE for C.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE for C.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 4 username: "C" expected_status: "TRUE_CLAIM" }
}

# --- Claim 5 "Bias in diagnostic algorithms" (child of 4) per-user views ---
# B created it ŌåÆ TRUE
steps {
  expectations { check_type: "USER_VIEW" claim_id: 5 username: "B" expected_status: "TRUE_CLAIM" }
}
# A: 8 is TRUE (conceded). 8 challenges 7. Rule D: 8 TRUE ŌåÆ 7 FALSE.
# 7 is child of 6. Rule A: child 7 FALSE ŌåÆ parent 6 FALSE.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE for A.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 5 username: "A" expected_status: "TRUE_CLAIM" }
}
# C: 6 is FALSE for C (child of 8 which is TRUE, 8 challenges 7 ŌåÆ 7 FALSE ŌåÆ 6 FALSE).
# Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 5 username: "C" expected_status: "TRUE_CLAIM" }
}

# --- Claim 6 "Bias can be mitigated..." (challengeŌåÆ5, root-level) per-user views ---
# A created it. After concede: 8/A = TRUE (conceded). 8 challenges 7. Rule D: 7 FALSE.
# 7 is child of 6. Rule A: child 7 FALSE ŌåÆ parent 6 FALSE for A.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE for A.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE for A.
# 4 challenges 2. 4 is TRUE. Rule D: incoming challenge 4 TRUE ŌåÆ 2 FALSE for A.
# 2 is child of 1. Rule A: child 2 FALSE ŌåÆ parent 1 FALSE for A.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 6 username: "A" expected_status: "FALSE_CLAIM" }
}
# B: 6 challenges 5. B has no entry on 6. ŌåÆ UNDETERMINED
steps {
  expectations { check_type: "USER_VIEW" claim_id: 6 username: "B" expected_status: "UNDETERMINED" }
}
# C: 8 is TRUE for C. 8 challenges 7. Rule D: 7 FALSE for C.
# 7 is child of 6. Rule A: 6 FALSE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 6 username: "C" expected_status: "FALSE_CLAIM" }
}

# --- Claim 7 "Diverse datasets exist..." (child of 6) per-user views ---
# A created it. 8 is TRUE (conceded). 8 challenges 7. Rule D: incoming challenge 8 TRUE ŌåÆ 7 FALSE for A.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 7 username: "A" expected_status: "FALSE_CLAIM" }
}
# B: no entry on 7 ŌåÆ UNDETERMINED
steps {
  expectations { check_type: "USER_VIEW" claim_id: 7 username: "B" expected_status: "UNDETERMINED" }
}
# C: 8 is TRUE for C. 8 challenges 7. Rule D: incoming challenge 8 TRUE ŌåÆ 7 FALSE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 7 username: "C" expected_status: "FALSE_CLAIM" }
}

# --- Claim 8 "Diverse data is hard..." (challengeŌåÆ7, root-level) per-user views ---
# C created it ŌåÆ TRUE
steps {
  expectations { check_type: "USER_VIEW" claim_id: 8 username: "C" expected_status: "TRUE_CLAIM" }
}
# A: 8 is TRUE for A (conceded). A concedes to C's challenge on claim 7.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 8 username: "A" expected_status: "TRUE_CLAIM" }
}
# B: no entry on 8 ŌåÆ UNDETERMINED
steps {
  expectations { check_type: "USER_VIEW" claim_id: 8 username: "B" expected_status: "UNDETERMINED" }
}

# --- Claim 9 "Rare diseases lack data..." (child of 8) per-user views ---
# C created it ŌåÆ TRUE
steps {
  expectations { check_type: "USER_VIEW" claim_id: 9 username: "C" expected_status: "TRUE_CLAIM" }
}
# A: 8 is TRUE for A (conceded). 8 is parent of 9. Rule A doesn't propagate parentŌåÆchild.
# But 9 is child of 8, and 8/A = TRUE. Rule B would need all children TRUE for parent.
# 9 has no children. For 9/A: children=none, incoming challenges=none ŌåÆ no rule fires.
# Wait ŌĆö 9 is a child of 8, but the cascade processes claim 9: it collects users from its own statuses (C),
# from children (none), from incoming challenges (none), from outgoing challenges (none).
# So only C is the user for claim 9. A doesn't get an entry on 9.
# Hmm, but the JSON shows A should have an entry on 9...
# Actually: claim 8 has outgoing challenge to 7. When processing claim 8, A gets entry (TRUE).
# But claim 9: its only connection is as child of 8. The cascade collects users from children
# of 9 (none), incoming challenges to 9 (none), outgoing challenges from 9 (none), and 9's own
# statuses (only C). So A never gets an entry on 9.
# This means 9/A should remain UNDETERMINED.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 9 username: "A" expected_status: "UNDETERMINED" }
}
# B: no entry on 9 ŌåÆ UNDETERMINED
steps {
  expectations { check_type: "USER_VIEW" claim_id: 9 username: "B" expected_status: "UNDETERMINED" }
}
# A: 8 is TRUE (conceded). 8 challenges 7. Rule D: 8 TRUE ŌåÆ 7 FALSE.
# 7 is child of 6. Rule A: child 7 FALSE ŌåÆ parent 6 FALSE.
# 6 challenges 5. 6 is FALSE. Rule C: incoming challenge 6 FALSE ŌåÆ 5 TRUE.
# 5 is child of 4. Rule B: child 5 TRUE ŌåÆ parent 4 TRUE.
# 4 challenges 2. 4 is TRUE. Rule D: incoming challenge 4 TRUE ŌåÆ 2 FALSE.
# 2 is child of 1. Rule A: child 2 FALSE ŌåÆ parent 1 FALSE.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 1 username: "A" expected_status: "FALSE_CLAIM" }
}
# B: 4 is TRUE for B. 4 challenges 2. Rule D: 2 FALSE for B.
# 2 is child of 1. Rule A: 1 FALSE for B.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 1 username: "B" expected_status: "FALSE_CLAIM" }
}
# C: 8 is TRUE for C. 8 challenges 7. Rule D: 7 FALSE for C.
# 7 is child of 6. Rule A: 6 FALSE for C.
# 6 challenges 5. 6 is FALSE. Rule C: 5 TRUE for C.
# 5 is child of 4. Rule B: 4 TRUE for C.
# 4 challenges 2. 4 is TRUE. Rule D: 2 FALSE for C.
# 2 is child of 1. Rule A: 1 FALSE for C.
steps {
  expectations { check_type: "USER_VIEW" claim_id: 1 username: "C" expected_status: "FALSE_CLAIM" }
}
