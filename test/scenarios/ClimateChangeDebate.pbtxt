name: "ClimateChangeDebate"

# =============================================================================
# PHASE 1: SETUP
# =============================================================================

steps {
  action { username: "DonaldTrump" event_type: "CREATE_USER" }
}

steps {
  action {
    username: "DonaldTrump"
    event_type: "CREATE_DEBATE"
    debate_topic: "Climate change is not impactful to us"
  }
}

steps {
  action { username: "DonaldTrump" event_type: "JOIN_DEBATE" debate_id: 1 }
}

steps {
  action { username: "DonaldTrump" event_type: "ENTER_DEBATE" debate_id: 1 }
  expectations { check_type: "ENGAGEMENT_STATE" username: "DonaldTrump" expected_action: "ACTION_DEBATING" }
}

# Verify debate root claim
steps {
  expectations {
    check_type: "CLAIM_EXISTS"
    claim_id: 1
  }
  expectations {
    check_type: "CLAIM_SENTENCE"
    claim_id: 1
    expected_claim_sentence: "Climate change is not impactful to us"
  }
}

# =============================================================================
# PHASE 2: DONALD TRUMP'S CLAIMS
# =============================================================================

# Claim 1: Sea level rise
steps {
  action { username: "DonaldTrump" event_type: "GO_TO_CLAIM" claim_id: 1 }
}

steps {
  action {
    username: "DonaldTrump"
    event_type: "ADD_CHILD_CLAIM"
    claim_text: "The sea level will rise 1/100th of an inch over the next 350 years"
    claim_description: "Trump's central argument for dismissing climate concern: he frames sea level rise as so slow that it poses no meaningful risk within any human timescale."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 2 }
  expectations {
    check_type: "CLAIM_SENTENCE"
    claim_id: 2
    expected_claim_sentence: "The sea level will rise 1/100th of an inch over the next 350 years"
  }
  expectations { check_type: "USER_VIEW" claim_id: 2 username: "DonaldTrump" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 1 to_claim_id: 2 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 2 }
}

# Claim 2: Global warming terminology
steps {
  action { username: "DonaldTrump" event_type: "GO_TO_CLAIM" claim_id: 1 }
}

steps {
  action {
    username: "DonaldTrump"
    event_type: "ADD_CHILD_CLAIM"
    claim_text: "Global warming was changed because the earth climate was warming and cooling so global warming was inaccurate"
    claim_description: "Trump argues the terminology shift from 'global warming' to 'climate change' is itself evidence that scientists' original warming hypothesis didn't hold up."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 3 }
  expectations {
    check_type: "CLAIM_SENTENCE"
    claim_id: 3
    expected_claim_sentence: "Global warming was changed because the earth climate was warming and cooling so global warming was inaccurate"
  }
  expectations { check_type: "USER_VIEW" claim_id: 3 username: "DonaldTrump" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 1 to_claim_id: 3 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 3 }
}

# =============================================================================
# PHASE 3: USER 2 CHALLENGES THE SEA LEVEL CLAIM
# =============================================================================

steps {
  action { username: "User2" event_type: "CREATE_USER" }
}

steps {
  action { username: "User2" event_type: "JOIN_DEBATE" debate_id: 1 }
}

steps {
  action { username: "User2" event_type: "ENTER_DEBATE" debate_id: 1 }
  expectations { check_type: "ENGAGEMENT_STATE" username: "User2" expected_action: "ACTION_DEBATING" }
}

# User 2 challenges claim 2 (sea level rise)
steps {
  action { username: "User2" event_type: "GO_TO_CLAIM" claim_id: 2 }
}

steps {
  action {
    username: "User2"
    event_type: "SUBMIT_CHALLENGE_CLAIM"
    claim_text: "Sea level will rise significantly more than 1/100th of an inch"
    challenge_description: "User2 disputes Trump's figure as a dramatic understatement, arguing it contradicts published scientific projections by orders of magnitude."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 4 }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 4 expected_claim_sentence: "Sea level will rise significantly more than 1/100th of an inch" }
  expectations { check_type: "USER_VIEW" claim_id: 4 username: "User2" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 4 to_claim_id: 2 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 4 }
}

# User 2 adds a child claim under the challenge with the evidence link
steps {
  action { username: "User2" event_type: "GO_TO_CLAIM" claim_id: 4 }
}

steps {
  action {
    username: "User2"
    event_type: "ADD_CHILD_CLAIM"
    claim_text: "https://www.climate.gov/news-features/understanding-climate/climate-change-global-sea-level"
    claim_description: "NOAA's climate.gov page compiling satellite altimetry and tide-gauge records, which document global mean sea level rising roughly 3.3mm per year — far above the rate Trump cited."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 5 }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 5 expected_claim_sentence: "https://www.climate.gov/news-features/understanding-climate/climate-change-global-sea-level" }
  expectations { check_type: "USER_VIEW" claim_id: 5 username: "User2" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "PARENT_CHILD" from_claim_id: 4 to_claim_id: 5 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 5 }
}

# Trump tries to challenge the evidence (claim 5)
steps {
  action { username: "DonaldTrump" event_type: "GO_TO_CLAIM" claim_id: 5 }
}

steps {
  action {
    username: "DonaldTrump"
    event_type: "SUBMIT_CHALLENGE_CLAIM"
    claim_text: "Science does not know"
    challenge_description: "Trump dismisses the NOAA data by casting broad doubt on the reliability of climate measurement and forecasting methods, without addressing the specific figures cited."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 6 }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 6 expected_claim_sentence: "Science does not know" }
  expectations { check_type: "USER_VIEW" claim_id: 6 username: "DonaldTrump" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 6 to_claim_id: 5 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 6 }
}

# User2 counters Trump's challenge
steps {
  action { username: "User2" event_type: "GO_TO_CLAIM" claim_id: 6 }
}

steps {
  action {
    username: "User2"
    event_type: "SUBMIT_CHALLENGE_CLAIM"
    claim_text: "Yes it does"
    challenge_description: "User2 rebuts the doubt by pointing out that satellite altimetry and tide-gauge instruments give scientists precise, cross-validated measurements of sea level change over decades."
  }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 7 }
  expectations { check_type: "CLAIM_SENTENCE" claim_id: 7 expected_claim_sentence: "Yes it does" }
  expectations { check_type: "USER_VIEW" claim_id: 7 username: "User2" expected_status: "TRUE_CLAIM" }
  expectations { check_type: "LINK_EXISTS" link_type: "CHALLENGE" from_claim_id: 7 to_claim_id: 6 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 7 }
}

# Donald Trump concedes the challenge
steps {
  action { username: "DonaldTrump" event_type: "CONCEDE_CHALLENGE" }
}

# =============================================================================
# FINAL STATE: Verify all claims, challenge links, and evidence child
# =============================================================================

steps {
  expectations { check_type: "CLAIM_EXISTS" claim_id: 1 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 2 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 3 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 4 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 5 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 6 }
  expectations { check_type: "CLAIM_EXISTS" claim_id: 7 }
  expectations { check_type: "COLLECTION_SIZE" expected_count: 7 }
  expectations { check_type: "LINK_COUNT" link_type: "PARENT_CHILD" expected_count: 3 }
  expectations { check_type: "LINK_COUNT" link_type: "CHALLENGE" expected_count: 3 }
}
